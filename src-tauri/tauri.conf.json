{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aura",
  "version": "0.3.1",
  "identifier": "com.tripp.aura",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "aura",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "closable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://discord.com https://discordapp.com; img-src 'self' https://shared.cloudflare.steamstatic.com https://cdn.cloudflare.steamstatic.com https://images.igdb.com https://cdn1.epicgames.com https://ubistatic-a.akamaihd.net data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMENDRTVEMEI1MEEyOUEKUldTYW9sQUxYYzRNSUFYNW9iUGFNSUNNOHhUbEFFdVd5S3VtMis5ejVlYnZOblRMKzR3bEJNaTUK",
      "endpoints": [
        "https://github.com/Trippledesigns/Aura/releases/latest/download/latest.json"
      ]
    }
  }
}